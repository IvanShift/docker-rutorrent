#!/usr/bin/env sh

if [ -f /config/rtorrent/.rtorrent.rc ]; then
  # replace d.directory by d.base_path
  sed -e "s|/usr/local/bin/postdl,\$d\.directory|/usr/local/bin/postdl,\$d\.base_path|g" -i /config/rtorrent/.rtorrent.rc

  # use new rTorrent 0.16+ DHT override setter
  sed -i -E 's/^dht\.port\.set[[:space:]]*=/dht.override_port.set =/' /config/rtorrent/.rtorrent.rc

  # use full-length rTorrent 0.16.14 commands; deprecated aliases now require rtorrent -D
  sed -i -E \
    -e 's/^[[:space:]]*execute2[[:space:]]*=/execute.nothrow =/' \
    -e 's/execute2=/execute.nothrow=/g' \
    -e 's/^[[:space:]]*schedule2[[:space:]]*=/schedule =/' \
    -e 's/^[[:space:]]*schedule_remove2[[:space:]]*=/schedule.remove =/' \
    -e 's/^[[:space:]]*port_range[[:space:]]*=/network.port_range.set =/' \
    -e 's/^[[:space:]]*port_random[[:space:]]*=/network.port_random.set =/' \
    -e 's/^[[:space:]]*dht[[:space:]]*=/dht.mode.set =/' \
    -e 's/^[[:space:]]*bind[[:space:]]*=/network.bind_address.set =/' \
    -e 's/^[[:space:]]*ip[[:space:]]*=/network.local_address.set =/' \
    -e 's/^[[:space:]]*scgi_local[[:space:]]*=/network.scgi.open_local =/' \
    -e 's/^[[:space:]]*scgi_port[[:space:]]*=/network.scgi.open_port =/' \
    -e 's/^[[:space:]]*proxy_address[[:space:]]*=/network.proxy_address.set =/' \
    -e 's/^[[:space:]]*key_layout[[:space:]]*=/keys.layout.set =/' \
    -e 's/^[[:space:]]*torrent_list_layout[[:space:]]*=/ui.torrent_list.layout.set =/' \
    -e 's/^[[:space:]]*network\.http\.max_open\.set[[:space:]]*=/network.http.max_total_connections.set =/' \
    -e 's/^[[:space:]]*network\.http\.max_open[[:space:]]*=/network.http.max_total_connections =/' \
    -e 's/^[[:space:]]*max_memory_usage[[:space:]]*=/pieces.memory.max.set =/' \
    /config/rtorrent/.rtorrent.rc

  # remove rTorrent 0.16.14 deprecated no-op settings from existing user configs
  sed -i -E \
    -e '/^[[:space:]]*trackers\.use_udp\.set[[:space:]]*=/d' \
    -e '/^[[:space:]]*encoding\.add[[:space:]]*=/d' \
    -e '/^[[:space:]]*encoding_list[[:space:]]*=/d' \
    -e '/^[[:space:]]*throttle\.ip[[:space:]]*=/d' \
    -e '/^[[:space:]]*dht\.throttle\.name[[:space:]]*=/d' \
    /config/rtorrent/.rtorrent.rc
fi

# replace /RPC by /RPC2
sed -e "s|'\/RPC'|'\/RPC2'|g" -i /config/rutorrent/conf/config.php

# update to php85
sed -e "s|'\/usr\/bin\/php8[0-9]'|'\/usr\/bin\/php85'|g" -i /config/rutorrent/conf/config.php

# ensure pathToExternals and config.php point to system curl
sed -i -E "s#/usr/(local/)?bin/curl#/usr/bin/curl#g" /config/rutorrent/conf/config.php

# update php cli reference in legacy rtorrent configs
if [ -f /config/rtorrent/.rtorrent.rc ]; then
  sed -i -E 's#/usr/bin/php(8[0-9])?#/usr/bin/php85#g' /config/rtorrent/.rtorrent.rc
fi

# ensure pathToExternals points to packaged binaries
PHP_BIN="$(command -v php85 || command -v php || true)"
if [ -z "${PHP_BIN}" ]; then
  echo "Skip pathToExternals update; php CLI not found" >&2
else
  "${PHP_BIN}" <<'PHP'
<?php
$file = '/config/rutorrent/conf/config.php';
if (!is_file($file)) {
    fwrite(STDERR, "Skip pathToExternals update; $file not found\n");
    exit(0);
}
$cfg = file_get_contents($file);
if ($cfg === false) {
    fwrite(STDERR, "Unable to read $file\n");
    exit(1);
}
$downloadDir = getenv('DOWNLOAD_DIRECTORY') ?: '/data/downloads';
$escapedDownloadDir = addcslashes($downloadDir, "\\'");
$topPattern = '/^\s*\$topDirectory\s*=.*$/m';
$topReplacement = "\t\$topDirectory = '{$escapedDownloadDir}';";
$cfg = preg_replace($topPattern, $topReplacement, $cfg, 1, $topReplaced);
if ($topReplaced === 0) {
    $cfg = preg_replace('/(\$overwriteUploadedTorrents\s*=.*\n)/', "$1{$topReplacement}\n", $cfg, 1);
}
$scgiHost = getenv('RU_SCGI_HOST') ?: 'unix:///run/rtorrent/rtorrent.sock';
$scgiPort = getenv('RU_SCGI_PORT') ?: '0';
$cfg = preg_replace('/^\s*\$scgi_host\s*=.*$/m', "\t\$scgi_host = \"{$scgiHost}\";", $cfg, 1);
$cfg = preg_replace('/^\s*\$scgi_port\s*=.*$/m', "\t\$scgi_port = {$scgiPort};", $cfg, 1);
$replacements = [
    'php' => '/usr/bin/php85',
    'curl' => '/usr/bin/curl',
    'ffmpeg' => '/usr/bin/ffmpeg',
    'unrar' => '/usr/local/bin/unrar',
    'sox' => '/usr/bin/sox',
    'mediainfo' => '/usr/bin/mediainfo',
    'dumptorrent' => '/usr/local/bin/dumptorrent',
];
if (!preg_match('/\$pathToExternals\s*=\s*array\s*\((.*?)\);/s', $cfg, $match, PREG_OFFSET_CAPTURE)) {
    exit(0);
}
$content = $match[1][0];
$offset = $match[1][1];
foreach ($replacements as $key => $value) {
    $entryPattern = '/"' . preg_quote($key, '/') . '"\s*=>\s*\'[^\']*\'/';
    $replacement = '"' . $key . '" => \'' . $value . '\'';
    if (preg_match($entryPattern, $content)) {
        $content = preg_replace($entryPattern, $replacement, $content, 1);
    } else {
        $content .= "\n\t\t\"$key\"\t=> '$value',";
    }
}
$cfg = substr_replace($cfg, $content, $offset, strlen($match[1][0]));
file_put_contents($file, $cfg);
PHP
fi
